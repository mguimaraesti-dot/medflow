# Prisma / PostgreSQL (Supabase)
# Transaction pooler (porta 6543), usado pela aplicação em runtime.
# pgbouncer=true é obrigatório (senão, erro "prepared statement already exists").
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@[POOLER_HOST]:6543/postgres?pgbouncer=true&connection_limit=1"
# Session pooler (porta 5432), usado pelo Prisma CLI (migrate/db seed).
# NÃO use a conexão direta (db.[PROJECT_REF].supabase.co) — exige IPv6.
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@[POOLER_HOST]:5432/postgres"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[ANON_KEY]"
SUPABASE_SERVICE_ROLE_KEY="[SERVICE_ROLE_KEY]"

# Ambiente
NODE_ENV="development"

# Seed (usadas só por prisma/seed.ts, nunca em runtime da aplicação)
SEED_ADMIN_EMAIL="admin@clinicamae.com.br"
SEED_ADMIN_PASSWORD="defina-uma-senha-forte-aqui"
SEED_ADMIN_NAME="Administrador MedFlow"
SEED_ORGANIZATION_NAME="Clínica MAE"

# Google Drive (Service Account) — anexos de Contas a Pagar.
# client_email/private_key vêm do JSON da service account (Google Cloud
# Console); a pasta em GOOGLE_DRIVE_FOLDER_ID precisa estar compartilhada
# com esse e-mail como Editor. Na Vercel, cole a private_key com as
# quebras de linha reais (\n) — o código também aceita \n escapado.
GOOGLE_SERVICE_ACCOUNT_EMAIL="[SERVICE_ACCOUNT]@[PROJECT_ID].iam.gserviceaccount.com"
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_DRIVE_FOLDER_ID="[FOLDER_ID]"
