# Prisma / PostgreSQL (Supabase)
# Transaction pooler (porta 6543), usado pela aplicação em runtime.
# pgbouncer=true é obrigatório (senão, erro "prepared statement already exists").
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@[POOLER_HOST]:6543/postgres?pgbouncer=true&connection_limit=1"
# Session pooler (porta 5432), usado pelo Prisma CLI (migrate/db seed).
# NÃO use a conexão direta (db.[PROJECT_REF].supabase.co) — exige IPv6.
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@[POOLER_HOST]:5432/postgres"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[ANON_KEY]"
SUPABASE_SERVICE_ROLE_KEY="[SERVICE_ROLE_KEY]"

# Ambiente
NODE_ENV="development"

# Seed (usadas só por prisma/seed.ts, nunca em runtime da aplicação)
SEED_ADMIN_EMAIL="admin@clinicamae.com.br"
SEED_ADMIN_PASSWORD="defina-uma-senha-forte-aqui"
SEED_ADMIN_NAME="Administrador MedFlow"
SEED_ORGANIZATION_NAME="Clínica MAE"

# Google Drive (OAuth2 com refresh token) — anexos de Contas a Pagar.
# Service Account foi descartada: contas de serviço não têm cota de
# armazenamento própria no Drive ("Service Accounts do not have storage
# quota"). CLIENT_ID/CLIENT_SECRET vêm das credenciais OAuth 2.0 do
# Google Cloud Console (tipo "Desktop app" ou "Web application");
# REFRESH_TOKEN é gerado uma vez, fora do código, autorizando o escopo
# https://www.googleapis.com/auth/drive.file como o dono do Drive (ex:
# via OAuth Playground ou um script local de consentimento) — a
# aplicação só reaproveita esse refresh token, nunca gera um novo
# sozinha. A pasta em GOOGLE_DRIVE_FOLDER_ID precisa ser acessível pela
# conta Google que gerou o refresh token.
GOOGLE_OAUTH_CLIENT_ID="[CLIENT_ID].apps.googleusercontent.com"
GOOGLE_OAUTH_CLIENT_SECRET="[CLIENT_SECRET]"
GOOGLE_OAUTH_REFRESH_TOKEN="[REFRESH_TOKEN]"
GOOGLE_DRIVE_FOLDER_ID="[FOLDER_ID]"

# Z-API (WhatsApp) — lembrete de cobrança de Contas a Pagar.
# INSTANCE_ID/TOKEN vêm do painel da instância Z-API; CLIENT_TOKEN é o
# "Client-Token" de segurança da conta (Z-API > Segurança). O cron
# diário (vercel.json) usa CRON_SECRET — a Vercel envia esse valor
# sozinha no header Authorization ao chamar a rota, não precisa
# configurar nada manualmente além de cadastrar a variável.
# WEBHOOK_SECRET é escolhido por você e cadastrado também no painel da
# Z-API (header customizado do webhook), pra garantir que só a Z-API
# consegue chamar /api/webhooks/zapi.
ZAPI_INSTANCE_ID="[INSTANCE_ID]"
ZAPI_TOKEN="[TOKEN]"
ZAPI_CLIENT_TOKEN="[CLIENT_TOKEN]"
ZAPI_WEBHOOK_SECRET="[WEBHOOK_SECRET]"
CRON_SECRET="[CRON_SECRET]"
