// Este arquivo é a fonte de verdade do modelo de dados do MedFlow.
// Task 1: apenas a configuração base (generator + datasource).
// Task 2: entram os models do domínio financeiro (ver MedFlow-Sprint1-Revisada.md).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // conexão via pooler (pgbouncer), usada em runtime
  directUrl = env("DIRECT_URL")   // conexão direta, usada pelo Prisma para migrations
}
