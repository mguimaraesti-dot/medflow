// Este arquivo é a fonte de verdade do modelo de dados do MedFlow.
// Domínio financeiro completo (ver docs/sprints/MedFlow-Sprint1-Revisada.md
// e docs/standards/MedFlow-Coding-Standards.md para as regras por trás
// de cada decisão de modelagem abaixo).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // conexão via pooler (pgbouncer), usada em runtime
  directUrl = env("DIRECT_URL") // conexão direta, usada pelo Prisma para migrations
}

// ============================================================
// TENANT (estrutural apenas — sem funcionalidade multiempresa na V1)
// ============================================================
model Organization {
  id        String   @id @default(cuid())
  name      String
  cnpj      String?  @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  cashRegisterDays   CashRegisterDay[]
  cashFlowEntries    CashFlowEntry[]
  accountsPayable    AccountsPayable[]
  payableAttachments AccountsPayableAttachment[]
  categories         Category[]
  paymentMethods     PaymentMethod[]
  suppliers          Supplier[]
  recurringBills     RecurringBill[]
  settings           OrganizationSettings?
  safe               Safe?
  safeMovements      SafeMovement[]

  @@map("organizations")
}

// Configurações da clínica — evita espalhar "settings" por várias tabelas
// conforme o sistema cresce (ex: horários usados nos alertas do Dashboard).
model OrganizationSettings {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id])

  tradeName String?
  legalName String?
  cnpj      String?
  phone     String?
  whatsapp  String?
  email     String?

  // Destino específico dos lembretes de WhatsApp de Contas a Pagar
  // (número comum OU id de grupo, ex: "120363...-group") — vazio usa
  // `whatsapp` acima como fallback (ver send-accounts-payable-whatsapp-
  // reminder.use-case.ts). O Relatório do Caixa Recepção NÃO usa este
  // campo, continua sempre em `whatsapp`.
  accountsPayableReminderWhatsapp String?

  currency    String @default("BRL")
  timezone    String @default("America/Sao_Paulo")
  openingTime String @default("08:00") // usado no alerta "caixa não aberto"
  closingTime String @default("18:00") // usado no alerta "caixa não fechado"

  // Hora (0-23, no timezone acima) em que o cron de lembretes de Contas a
  // Pagar dispara — checado a cada chamada da rota, não um schedule do
  // Vercel (plano Hobby só permite cron nativo 1x/dia, sem configuração
  // dinâmica; ver /api/cron/accounts-payable-reminders).
  reminderSendHour Int @default(7)

  logoUrl      String?
  primaryColor String  @default("#0F172A")
  theme        String  @default("system") // "light" | "dark" | "system"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("organization_settings")
}

// ============================================================
// RBAC
// ============================================================
enum RoleName {
  ADMIN
  OWNER
  SECRETARY
  FINANCE
  ACCOUNTANT
}

model Role {
  id          String       @id @default(cuid())
  name        RoleName     @unique
  description String?
  permissions Permission[]
  users       User[]

  @@map("roles")
}

model Permission {
  id    String @id @default(cuid())
  key   String @unique
  // ex: "cashflow:create", "cashflow:reverse", "cash-register:open",
  //     "cash-register:close", "cash-register:reopen",
  //     "payable:create", "payable:pay", "users:manage"
  roles Role[]

  @@map("permissions")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  // Criado via trigger em auth.users (convite de Admin/Gerente ou
  // primeiro login via Google) — sem roleId até alguém atribuir um
  // perfil pela tela de Gestão de Acessos.
  PENDING
}

model User {
  id             String        @id @default(cuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  name           String
  email          String @unique
  supabaseAuthId String @unique

  roleId String?
  role   Role?   @relation(fields: [roleId], references: [id])

  status      UserStatus @default(ACTIVE)
  lastLoginAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  auditLogs                  AuditLog[]
  cashFlowEntries            CashFlowEntry[]             @relation("EntryCreatedBy")
  openedRegisters            CashRegisterDay[]           @relation("RegisterOpenedBy")
  closedRegisters            CashRegisterDay[]           @relation("RegisterClosedBy")
  reopenedRegisters          CashRegisterDay[]           @relation("RegisterReopenedBy")
  handoffConfirmedRegisters  CashRegisterDay[]           @relation("RegisterHandoffConfirmedBy")
  safeMovements              SafeMovement[]
  confirmedSafeMovements     SafeMovement[]              @relation("SafeMovementConfirmedBy")
  cancelledSafeMovements     SafeMovement[]              @relation("SafeMovementCancelledBy")
  createdPayables            AccountsPayable[]           @relation("PayableCreatedBy")
  paidPayables               AccountsPayable[]           @relation("PayablePaidBy")
  deletedPayables            AccountsPayable[]           @relation("PayableDeletedBy")
  uploadedPayableAttachments AccountsPayableAttachment[] @relation("PayableAttachmentCreatedBy")

  @@index([organizationId])
  @@map("users")
}

// ============================================================
// AUDITORIA
// ============================================================
enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  REVERSAL
  CASH_REGISTER_OPENED
  CASH_REGISTER_CLOSED
  CASH_REGISTER_REOPENED
  PAYMENT_CONFIRMED
  CASH_REGISTER_CONFERENCE_REQUESTED
  CASH_REGISTER_HANDOFF_CONFIRMED
  CASH_REGISTER_CONFERENCE_REJECTED
  SAFE_SANGRIA
  SAFE_MANUAL_ADJUSTMENT
  WHATSAPP_REMINDER_SENT
}

model AuditLog {
  id     String  @id @default(cuid())
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  entity    String
  entityId  String
  action    AuditAction
  reason    String? // usado obrigatoriamente em CASH_REGISTER_REOPENED
  before    Json?
  after     Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime    @default(now())

  @@index([entity, entityId])
  @@index([userId])
  @@map("audit_logs")
}

// ============================================================
// CADASTROS FINANCEIROS BASE
// ============================================================
enum CategoryType {
  IN
  OUT
}

model Category {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  name         String
  type         CategoryType
  color        String       @default("#64748B") // hex, usado no Dashboard e nos badges
  icon         String? // nome do ícone lucide-react (ex: "zap", "home", "wallet")
  displayOrder Int          @default(0)
  active       Boolean      @default(true)

  cashFlowEntries CashFlowEntry[]
  accountsPayable AccountsPayable[]
  recurringBills  RecurringBill[]

  @@unique([organizationId, name, type])
  @@map("categories")
}

model PaymentMethod {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  name         String // Dinheiro, PIX, Cartão Débito, Cartão Crédito, Boleto, Transferência
  displayOrder Int     @default(0)
  active       Boolean @default(true)
  isCash       Boolean @default(false) // usado no cálculo de Dinheiro Esperado (Motor de Tesouraria)

  cashFlowEntries CashFlowEntry[]

  @@unique([organizationId, name])
  @@map("payment_methods")
}

enum SupplierPersonType {
  PESSOA_FISICA
  PESSOA_JURIDICA
}

model Supplier {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  name        String
  personType  SupplierPersonType @default(PESSOA_JURIDICA)
  document    String? // CPF/CNPJ, opcional na Sprint 1
  contactName String? // pessoa de contato, opcional (Sprint 02 - UX)
  phone       String? // telefone de contato, opcional (Sprint 02 - UX)
  email       String?
  notes       String?
  active      Boolean            @default(true)

  accountsPayable AccountsPayable[]
  recurringBills  RecurringBill[]

  @@index([organizationId])
  @@map("suppliers")
}

// ============================================================
// CAIXA DIÁRIO
// ============================================================
enum CashRegisterStatus {
  OPEN
  PENDING_CONFERENCE
  CLOSED
}

model CashRegisterDay {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  date   DateTime           @db.Date
  status CashRegisterStatus @default(OPEN)

  openingBalance Decimal  @db.Decimal(14, 2)
  totalIn        Decimal? @db.Decimal(14, 2)
  totalOut       Decimal? @db.Decimal(14, 2)
  closingBalance Decimal? @db.Decimal(14, 2)

  openedByUserId String
  openedBy       User     @relation("RegisterOpenedBy", fields: [openedByUserId], references: [id])
  openedAt       DateTime @default(now())

  closedByUserId String?
  closedBy       User?     @relation("RegisterClosedBy", fields: [closedByUserId], references: [id])
  closedAt       DateTime?

  reopenedByUserId String?
  reopenedBy       User?     @relation("RegisterReopenedBy", fields: [reopenedByUserId], references: [id])
  reopenedAt       DateTime?
  reopenCount      Int       @default(0)

  // Motor de Tesouraria (ADR — docs/decisions/adr-tesouraria.md): dupla
  // conferência no fechamento — secretária presta contas (countedAmount),
  // gerência confere e confirma o handoff (receivedAmount) ou rejeita.
  expectedCashAmount  Decimal? @db.Decimal(14, 2)
  countedAmount       Decimal? @db.Decimal(14, 2)
  receivedAmount      Decimal? @db.Decimal(14, 2)
  difference          Decimal? @db.Decimal(14, 2)
  confirmedDifference Decimal? @db.Decimal(14, 2)
  closureNote         String?

  handoffConfirmedByUserId String?
  handoffConfirmedBy       User?     @relation("RegisterHandoffConfirmedBy", fields: [handoffConfirmedByUserId], references: [id])
  handoffConfirmedAt       DateTime?

  rejectedAt      DateTime?
  rejectionReason String?

  cashFlowEntries CashFlowEntry[]
  safeMovements   SafeMovement[]

  @@unique([organizationId, date])
  @@index([organizationId, status])
  @@map("cash_register_days")
}

// ============================================================
// FLUXO DE CAIXA (imutável — correções via estorno)
// ============================================================
enum CashFlowType {
  IN
  OUT
}

model CashFlowEntry {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  cashRegisterDayId String
  cashRegisterDay   CashRegisterDay @relation(fields: [cashRegisterDayId], references: [id])

  type        CashFlowType
  amount      Decimal      @db.Decimal(14, 2)
  description String?
  occurredAt  DateTime     @default(now())

  // obrigatórios no formulário conforme o tipo (Refinamento UX Caixa
  // Recepção): nome do paciente pagando (Entrada) / justificativa da
  // retirada (Saída). Nullable aqui pois estornos gerados pelo sistema
  // não passam por essa validação.
  patientName      String?
  withdrawalReason String?

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  paymentMethodId String
  paymentMethod   PaymentMethod @relation(fields: [paymentMethodId], references: [id])

  // vínculo opcional com Contas a Pagar (usado a partir da Sprint 2)
  accountsPayableId String?
  accountsPayable   AccountsPayable? @relation(fields: [accountsPayableId], references: [id])

  createdByUserId String
  createdBy       User     @relation("EntryCreatedBy", fields: [createdByUserId], references: [id])
  createdAt       DateTime @default(now())

  // estorno
  isReversed        Boolean        @default(false)
  reversalOfEntryId String?        @unique
  reversalOfEntry   CashFlowEntry? @relation("EntryReversal", fields: [reversalOfEntryId], references: [id])
  reversedByEntry   CashFlowEntry? @relation("EntryReversal")

  @@index([organizationId, cashRegisterDayId])
  @@index([cashRegisterDayId])
  @@index([categoryId])
  @@index([organizationId, occurredAt])
  @@map("cash_flow_entries")
}

// ============================================================
// CONTAS A PAGAR (schema completo agora; feature implementada na Sprint 2)
// ============================================================
enum PayableStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

/**
 * Origem da confirmação de pagamento — hoje só SYSTEM é possível (WhatsApp ainda não integrado, só preparado via `publicToken`).
 */
enum PaymentConfirmationSource {
  SYSTEM
  WHATSAPP
}

/**
 * Fonte do dinheiro usada pra pagar a conta — Banco (padrão, sem efeito no Cofre) ou Cofre (dinheiro em espécie, debita o saldo e gera SafeMovement).
 */
enum PaymentOrigin {
  BANCO
  COFRE
}

model AccountsPayable {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  publicToken String @unique @default(uuid()) // link seguro futuro (WhatsApp)

  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  description String
  amount      Decimal  @db.Decimal(14, 2)
  dueDate     DateTime @db.Date

  barcode       String?
  digitableLine String?
  pixKey        String?
  qrCodeUrl     String?
  boletoPdfUrl  String?

  status PayableStatus @default(PENDING)

  // Fonte do dinheiro escolhida no cadastro/edição (distinto de `paidVia`,
  // que é o canal de confirmação) — decide se a confirmação de pagamento
  // debita o Cofre automaticamente (ver pay-accounts-payable.use-case).
  paymentOrigin PaymentOrigin @default(BANCO)

  recurringBillId  String?
  recurringBill    RecurringBill? @relation(fields: [recurringBillId], references: [id])
  occurrenceNumber Int? // posição desta conta na série (1, 2, 3...) — null se não for recorrente

  createdByUserId String // quem cadastrou (ex: Secretária)
  createdBy       User                       @relation("PayableCreatedBy", fields: [createdByUserId], references: [id])
  paidByUserId    String? // quem confirmou o pagamento (Financeiro/Proprietário)
  paidBy          User?                      @relation("PayablePaidBy", fields: [paidByUserId], references: [id])
  paidAt          DateTime?
  paidVia         PaymentConfirmationSource?

  // Cobrança via WhatsApp (Z-API) — lembrete automático (cron diário)
  // até a conta ser paga. reminderDaysBefore conta a partir de dueDate
  // (ex: 5 = começa a lembrar 5 dias antes do vencimento).
  // lastReminderSentAt evita reenviar mais de uma vez no mesmo dia.
  // lastReminderMessageId guarda o id da mensagem de texto (Z-API) do
  // cartão-resumo — usado pra casar a resposta "PAGO" com a conta certa
  // quando a pessoa responde citando essa mensagem no WhatsApp (o
  // número é único pra clínica inteira, nunca por conta, então o
  // telefone sozinho não desambigua nada — ver
  // handle-zapi-webhook.use-case.ts).
  // Interruptor por conta — desliga o lembrete sem exigir um
  // reminderDaysBefore "mágico" pra significar "nunca" (nenhum valor
  // numérico fecha isso, já que o cron usa `>=`, nunca `=`). Default
  // true preserva o comportamento atual de todas as contas existentes.
  reminderEnabled      Boolean   @default(true)
  reminderDaysBefore   Int       @default(5)
  lastReminderSentAt   DateTime?
  lastReminderMessageId String?

  // Soft delete (Sprint 05) — nunca DELETE físico; conta some da listagem
  // padrão mas continua no banco pra auditoria e restauração. Só permitido
  // enquanto status === PENDING (ver soft-delete-accounts-payable.use-case).
  deletedAt       DateTime?
  deletedByUserId String?
  deletedBy       User?     @relation("PayableDeletedBy", fields: [deletedByUserId], references: [id])
  deletionReason  String?

  cashFlowEntries CashFlowEntry[]
  // Movimentação do Cofre gerada ao confirmar pagamento com paymentOrigin
  // COFRE (ver ACCOUNTS_PAYABLE_PAYMENT em SafeMovementType) — no máximo 1
  // na prática (uma conta só é paga uma vez).
  safeMovements   SafeMovement[]
  attachments     AccountsPayableAttachment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, status])
  @@index([dueDate])
  @@index([organizationId, deletedAt])
  @@index([organizationId, dueDate])
  @@index([organizationId, status, dueDate])
  @@index([organizationId, status, paidAt])
  @@index([supplierId])
  @@index([categoryId])
  @@index([recurringBillId])
  @@map("accounts_payable")
}

/**
 * Anexos de uma Conta a Pagar (boleto, comprovante, nota fiscal) — o
 * arquivo em si vive no Google Drive (Service Account, escopo
 * `drive.file`, pasta única `GOOGLE_DRIVE_FOLDER_ID`); aqui só o
 * metadado. Exclusão é sempre física (nunca soft delete, diferente de
 * `AccountsPayable`) — remover o anexo também apaga o arquivo no Drive,
 * best-effort (ver delete-accounts-payable-attachment.use-case.ts: um
 * 404 do Drive, arquivo já removido manualmente por fora, não impede
 * remover o registro).
 */
model AccountsPayableAttachment {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  accountsPayableId String
  accountsPayable   AccountsPayable @relation(fields: [accountsPayableId], references: [id])

  driveFileId String // id do arquivo no Google Drive (drive.files.create response.id)
  fileName    String
  mimeType    String
  sizeBytes   Int

  createdByUserId String
  createdBy       User     @relation("PayableAttachmentCreatedBy", fields: [createdByUserId], references: [id])
  createdAt       DateTime @default(now())

  @@index([organizationId])
  @@index([accountsPayableId])
  @@map("accounts_payable_attachments")
}

/**
 * Mensal/Quinzenal/Semanal/Anual — usado só pelas recorrências criadas via checkbox "Conta recorrente" (Sprint de Recorrências); o painel antigo (dueDay) sempre grava MONTHLY.
 */
enum RecurrencePeriodicity {
  MONTHLY
  BIWEEKLY
  WEEKLY
  YEARLY
}

model RecurringBill {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  description String
  amount      Decimal @db.Decimal(14, 2)
  dueDay      Int // dia do mês (1–28, evita problema em fevereiro)
  active      Boolean @default(true)

  // Campos novos (Sprint de Recorrências) — nullable pra não quebrar as
  // recorrências já criadas pelo painel antigo, que só usa dueDay.
  periodicity    RecurrencePeriodicity @default(MONTHLY)
  maxOccurrences Int? // null = sem prazo
  firstDueDate   DateTime?             @db.Date // vencimento da 1ª ocorrência gerada

  payables AccountsPayable[]

  createdAt DateTime @default(now())

  @@index([organizationId])
  @@index([supplierId])
  @@map("recurring_bills")
}

// ============================================================
// TESOURARIA (Cofre — docs/decisions/adr-tesouraria.md)
// ============================================================
enum SafeMovementType {
  FUNDING // abastecimento do caixa (Cofre -> Caixa)
  SANGRIA // sangria (Caixa -> Cofre)
  CASH_REGISTER_HANDOFF // fechamento confirmado (Caixa -> Cofre)
  MANUAL_ADJUSTMENT // só Admin — amount pode ser negativo (único tipo sem direção implícita)
  ACCOUNTS_PAYABLE_PAYMENT // pagamento de Conta a Pagar com dinheiro do Cofre (Cofre -> Fornecedor)
}

// PENDING só é usado por CASH_REGISTER_HANDOFF (fechamento de caixa aguardando
// conferência do Gerente) — todos os outros tipos nascem CONFIRMED e nunca mudam.
enum SafeMovementStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model Safe {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())

  movements SafeMovement[]

  @@map("safes")
}

// Saldo nunca é persistido como fonte da verdade — sempre derivado da soma
// das movimentações CONFIRMED (Coding Standards, item 18.1). `amount`/`type`/
// os `relatedX` nunca mudam depois de criados e a linha nunca é excluída —
// a única exceção é a transição de `status` (PENDING -> CONFIRMED/CANCELLED)
// via confirm-safe-movement/cancel-safe-movement, exclusiva do fechamento de
// caixa aguardando conferência gerencial.
model SafeMovement {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  safeId String
  safe   Safe   @relation(fields: [safeId], references: [id])

  type   SafeMovementType
  amount Decimal            @db.Decimal(14, 2)
  status SafeMovementStatus @default(CONFIRMED)

  relatedCashRegisterDayId String?
  relatedCashRegisterDay   CashRegisterDay? @relation(fields: [relatedCashRegisterDayId], references: [id])

  relatedAccountsPayableId String?
  relatedAccountsPayable   AccountsPayable? @relation(fields: [relatedAccountsPayableId], references: [id])

  performedByUserId String
  performedBy       User    @relation(fields: [performedByUserId], references: [id])
  reason            String? // obrigatório para MANUAL_ADJUSTMENT (validado no DTO)

  confirmedByUserId String?
  confirmedBy       User?     @relation("SafeMovementConfirmedBy", fields: [confirmedByUserId], references: [id])
  confirmedAt       DateTime?

  cancelledByUserId String?
  cancelledBy       User?     @relation("SafeMovementCancelledBy", fields: [cancelledByUserId], references: [id])
  cancelledAt       DateTime?
  cancelReason      String? // obrigatório ao cancelar uma pendência (validado no DTO)

  createdAt DateTime @default(now())

  @@index([organizationId, type])
  @@index([organizationId, status])
  @@index([relatedCashRegisterDayId])
  @@index([relatedAccountsPayableId])
  @@index([safeId, type])
  @@index([organizationId, createdAt])
  @@index([organizationId, confirmedAt])
  @@map("safe_movements")
}
